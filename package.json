{
  "name": "fitness-tracker-app",
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "vite build",
    "start": "vite build && electron main.js",
    "web:dev": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "package": "node package-app.js",
    "build:android": "vite build && node copy-assets.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "chart.js": "^4.4.1",
    "firebase": "^10.8.0"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.1.4",
    "dotenv": "^16.4.5"
  },
  "build": {
    "appId": "com.aurafit.app",
    "productName": "AuraFit",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  }
}
